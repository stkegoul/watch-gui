# Database Configuration
# PostgreSQL connection URL for syncing transactions, identities, balances, and ledgers
# Format: postgres://user:password@host:port/database?sslmode=disable
DB_URL=postgres://user:password@localhost:5432/blnk?sslmode=disable

# Watch Script Configuration
# Directory where watch scripts are stored (default: "watch_scripts")
WATCH_SCRIPT_DIR=watch_scripts

# Git Repository Configuration (optional)
# Git repository URL for watch scripts
WATCH_SCRIPT_GIT_REPO=

# Git branch to use for watch scripts (default: "main")
WATCH_SCRIPT_GIT_BRANCH=main

# Cloud Anomaly Flagging Configuration
# Primary cloud URL for anomaly flagging endpoint
# The system will POST to {URL}/flag/{transaction_id}
CLOUD_ANOMALY_PRIMARY_URL=

# Secondary cloud URL for anomaly flagging (optional, used as fallback)
CLOUD_ANOMALY_SECONDARY_URL=

# Backup cloud URL for anomaly flagging (optional, used as fallback)
CLOUD_ANOMALY_BACKUP_URL=

# API key for cloud anomaly flagging (optional, sent as Bearer token in Authorization header)
CLOUD_ANOMALY_API_KEY=

# Risk threshold for cloud flagging (default: 0.5)
# Transactions with risk score >= this threshold will be flagged
CLOUD_ANOMALY_RISK_THRESHOLD=0.5

# Enable/disable cloud anomaly flagging (set to "false" to disable)
# Default: enabled (if not set or set to any value other than "false")
CLOUD_ANOMALY_ENABLED=true
